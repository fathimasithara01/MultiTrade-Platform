# ─────────────────────────────────────────────────────────────────────────────
# MultiTrade Platform — Environment Configuration
# Copy to .env and fill in real values before running the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tradecore
DB_SSLMODE=disable           # disable | require | verify-full (use verify-full in prod)

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=                  # leave empty for no-auth local dev

# ── Kafka / Redpanda ──────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092 # comma-separated for multi-broker: host1:9092,host2:9092

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a cryptographically random 32+ byte string in production.
# Generate one: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
JWT_ACCESS_EXPIRY=15m        # access token lifetime
JWT_REFRESH_EXPIRY=168h      # refresh token lifetime (7 days)
